# Copy to .env for local development (server.js reads real env vars; locally
# you can set these in the shell before `npm run dev:api`, or use a tool like
# dotenv — on Railway these all go in the Variables tab).

# Port for the API/server. Railway injects PORT automatically — don't set it there.
PORT=8787

# Where the SQLite database lives. On Railway set this to your volume mount
# path (e.g. /data). Locally defaults to ./data if unset.
DATA_DIR=

# REQUIRED for hub sync: shared secret between the hub and this portal.
# Generate one: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SYNC_SECRET=

# Stripe secret key (sk_live_... or sk_test_...) for milestone payments.
STRIPE_SECRET_KEY=

# OpenRouter key + model for the client-facing AI chat.
OPENROUTER_API_KEY=
PORTAL_AI_MODEL=

# Optional: AI messages allowed per client per hour (default 20).
CHAT_LIMIT_PER_HOUR=20
